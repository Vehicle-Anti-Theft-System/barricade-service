# barricade-service/.env — copy to .env and tune for this gate PC.
# Every variable has a sensible local default; uncomment and edit what you need.

# ── Central backend (server-to-server, called by the API Agent only) ──
# API Agent posts /api/verify/* here with X-API-Key. The browser never
# reaches this URL directly — the agent's /api/* proxy fronts it.
# Production example: http://<EC2-IP>:8000  or  https://api.example.com
BACKEND_BASE_URL=http://localhost:8000

# Must match backend-service `API_KEY` exactly (sent as X-API-Key).
# Generate with:  openssl rand -hex 32
BACKEND_API_KEY=change-me-to-a-long-random-secret

# Retries + timeouts for the agent's HTTP calls to the backend.
BACKEND_MAX_RETRIES=4
BACKEND_RETRY_BACKOFF_SEC=0.6
BACKEND_HTTP_TIMEOUT_SEC=25.0

# ── API Agent (this gate's identity in the backend) ──────────────────
# UUID of this barricade in backend MongoDB. Default matches backend-service
# seed.py so local dev works out of the box; in production, set to the UUID
# printed by seed.py on the deployed database.
DEFAULT_BARRICADE_ID=ba11ad01-dead-4ead-beef-feedbadc0de1

# How many times the agent retries /capture on the ANPR service.
ANPR_MAX_RETRIES=3
ANPR_RETRY_DELAY=2.0

# ── RFID Service ─────────────────────────────────────────────────────
# The RFID service pushes { "rfid_tag" } to the agent. One-way.
API_AGENT_RFID_INGEST_URL=http://localhost:8080/rfid/scan

# Mode/port/baud precedence:   env var  >  barricade_config.json  >  default
# The dashboard's Admin → Configuration page writes barricade_config.json,
# so you can also set these from the UI at runtime (changes apply live —
# no service restart needed).
#
#   mode: "serial" = read from Arduino/USB, "mock" = cycle seed tags on /trigger
RFID_MODE=serial
#
# Serial device path. Leave unset to auto-detect by USB VID
# (Arduino / CH340 / FTDI / CP210x).
#   macOS:   /dev/cu.usbmodem14201  or  /dev/cu.usbserial-1420
#   Linux:   /dev/ttyUSB0  or  /dev/ttyACM0
#   Windows: COM3
# RFID_SERIAL_PORT=/dev/cu.usbmodem14201
#
# Must match the Arduino sketch's Serial.begin(...).
# RFID_BAUD_RATE=9600

# ── ANPR Service ─────────────────────────────────────────────────────
ANPR_SERVICE_URL=http://localhost:8001
ANPR_CAMERA_INDEX=0

# ── Gate actuator (agent → RFID service → Arduino serial) ───────────
# After a successful RFID + ANPR verification, the API Agent calls
# POST {RFID_SERVICE_URL}/gate/open on the local RFID service, which writes
# "OPEN\n" to the already-open serial port. Only override if the RFID
# service runs on a non-default host/port.
RFID_SERVICE_URL=http://localhost:8002

# ── Dashboard (Vite env vars — compiled into the SPA at build time) ──
# WebSocket host:port for the agent.
VITE_API_AGENT_HOST=localhost:8080

# MJPEG host:port for the camera preview.
VITE_ANPR_HOST=localhost:8001

# Dashboard → API Agent base URL for JWT login + /admin CRUD
# (orders / trucks / drivers / alerts). The agent proxies /api/* to
# BACKEND_BASE_URL server-side; the browser never calls the backend directly.
#   - Must be the **API Agent** origin (not the backend).
#   - Leave unset for offline demo login (any employee ID + password barricade123).
VITE_BACKEND_URL=http://localhost:8080

# ── Logging ──────────────────────────────────────────────────────────
# Applies to api_agent, rfid_service, anpr_service.
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── run-barricade.sh options (set at invocation, not here) ───────────
# Starts: api_agent → anpr_service → rfid_service → dashboard_service
#   SKIP_ANPR=1 ./run-barricade.sh        # skip the camera / ML service
#   SKIP_DASHBOARD=1 ./run-barricade.sh   # skip the Vite dev server
