# ── Backend (remote) ────────────────────────────────────
# API Agent calls this for POST /api/verify/*. In production the backend runs on AWS
# (or any cloud); use your deployed API base URL (no trailing slash).
# Example: https://api.yourdomain.com  or  https://xxxx.execute-api.region.amazonaws.com
# BACKEND_BASE_URL=https://your-backend-api.example.com

# Local backend dev only (if you run backend-service on this machine):
BACKEND_BASE_URL=http://localhost:8000

# Required — must match backend-service `API_KEY` exactly (header X-API-Key on every /api call).
BACKEND_API_KEY=change-me-to-a-long-random-secret

# Retries for transient errors (502/503/504, connection drops) — tune for flaky links
BACKEND_MAX_RETRIES=4
BACKEND_RETRY_BACKOFF_SEC=0.6
BACKEND_HTTP_TIMEOUT_SEC=25.0

# ── API Agent ─────────────────────────────────────────
# Barricade UUID — must exist in backend MongoDB (required for live RFID→backend).
# Default matches backend-service seed.py (stable id). Re-run seed anytime to refresh orders.
DEFAULT_BARRICADE_ID=ba11ad01-dead-4ead-beef-feedbadc0de1

# ANPR retry config
ANPR_MAX_RETRIES=3
ANPR_RETRY_DELAY=2.0

# ── RFID Service ──────────────────────────────────────
API_AGENT_RFID_INGEST_URL=http://localhost:8080/rfid/scan

# ── ANPR Service ──────────────────────────────────────
ANPR_SERVICE_URL=http://localhost:8001
ANPR_CAMERA_INDEX=0

# ── Dashboard (Vite env vars) ─────────────────────────
VITE_API_AGENT_HOST=localhost:8080
VITE_ANPR_HOST=localhost:8001

# Same host as BACKEND_BASE_URL — enables JWT login + /admin UI (orders/trucks/drivers).
# Leave unset to use offline demo login (any employee ID + password barricade123).
VITE_BACKEND_URL=http://localhost:8000

# Optional: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ── run-barricade.sh ───────────────────────────────────
# Starts: api_agent, anpr_service, rfid_service, dashboard_service
# Optional: SKIP_ANPR=1 SKIP_DASHBOARD=1 ./run-barricade.sh
